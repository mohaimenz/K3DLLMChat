# k3d LLM Inference Pod - Development Environment Variables

# Model configuration
MODEL_ID=Qwen/Qwen2.5-0.5B-Instruct
SYSTEM_MESSAGE=You are a helpful assistant. Answer clearly and directly. If unsure, say so.

# Inference configuration
INFERENCE_HOST=localhost
INFERENCE_PORT=8001
INFERENCE_TIMEOUT=120

# Kubernetes
NAMESPACE=llm-sidecar

# Docker registry
REGISTRY_HOST=127.0.0.1
REGISTRY_PORT=5001
REGISTRY_NAME=llm-mvp-registry

# Development ports
FRONTEND_PORT=3000
FASTAPI_PORT=8000
INFERENCE_INTERNAL_PORT=8001
