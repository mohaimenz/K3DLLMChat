# k3d LLM Inference Pod - Development Environment Variables

# Model configuration
MODEL_ID=Qwen/Qwen2.5-0.5B-Instruct
SYSTEM_MESSAGE=You are a helpful assistant. Answer in 1-2 sentences only. Be concise and brief.

# Inference configuration
INFERENCE_HOST=localhost
INFERENCE_PORT=8001
INFERENCE_TIMEOUT=120

# Kubernetes
NAMESPACE=k3d-llm-sidecar

# Docker registry
REGISTRY_HOST=127.0.0.1
REGISTRY_PORT=5001
REGISTRY_NAME=k3d-llm-sidecar-registry

# Development ports
FRONTEND_PORT=3000
FASTAPI_PORT=8000
INFERENCE_INTERNAL_PORT=8001
